{{/* Generates RSS enclosure/media tags for a post's image.
     Handles local assets, root-relative paths, and external URLs.
     SVGs are emitted without width/height (unsupported by Hugo). */}}
{{- with $path := .path -}}

  {{- $isLocal    := not (or (strings.HasPrefix $path "http://") (strings.HasPrefix $path "https://") (strings.HasPrefix $path "/")) -}}
  {{- $isRooted   := and (not $isLocal) (strings.HasPrefix $path "/") -}}

  {{- $res := "" -}}
  {{- $url := "" -}}

  {{- if $isLocal -}}
    {{- with resources.Get $path -}}
      {{- $res = . -}}
      {{- $url = .RelPermalink | absURL -}}
    {{- end -}}
  {{- else if $isRooted -}}
    {{- $remote := printf "%s%s" site.BaseURL (strings.TrimLeft "/" $path) -}}
    {{- with resources.GetRemote $remote -}}
      {{- $res = . -}}
      {{- $url = .Permalink -}}
    {{- end -}}
  {{- else -}}
    {{- with resources.GetRemote $path -}}
      {{- $res = . -}}
      {{- $url = .Permalink -}}
    {{- end -}}
  {{- end -}}

  {{- with $res -}}
    {{- $isSVG := eq .MediaType.SubType "svg+xml" -}}
<enclosure url="{{ $url }}" length="" type="{{ .MediaType }}" />
    {{- if $isSVG }}
<media:thumbnail url="{{ $url }}" />
<media:content url="{{ $url }}" medium="{{ .MediaType.MainType }}" type="{{ .MediaType }}">
    {{- else }}
<media:thumbnail url="{{ $url }}" width="{{ .Width }}" height="{{ .Height }}" />
<media:content url="{{ $url }}" medium="{{ .MediaType.MainType }}" type="{{ .MediaType }}" width="{{ .Width }}" height="{{ .Height }}">
    {{- end }}
    <media:title type="html">{{ . }}</media:title>
</media:content>
  {{- end -}}

{{- end -}}